# ============================================
# Local Environment Configuration Template
# ============================================
# 
# This file serves as a template for local development configuration.
# To use it:
#   1. Copy this file to 'application-local.yaml' in the same directory
#   2. Replace all placeholder values with your actual credentials
#   3. Activate the 'local' profile by setting spring.profiles.active=local
#      (via environment variable, IDE configuration, or command line)
#
# Note: application-local.yaml is git-ignored and should never be committed
# ============================================

spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/operations-analytics-dashboard
    username: YOUR_DB_USERNAME
    password: YOUR_DB_PASSWORD
  mail:
    host: smtp.example.com
    port: 587
    username: no-reply@example.com
    password: change-me
    properties:
      mail.smtp.auth: true
      mail.smtp.starttls.enable: true

app:
  email:
    from-address: no-reply@example.com
    base-url: http://localhost:4200
    verification-token-ttl-hours: 24
    reset-token-ttl-hours: 1

# JWT Configuration
jwt:
  secret: YOUR_JWT_SECRET_KEY_MIN_32_CHARS_LONG

# Plaid API Configuration
plaid:
  client-id: YOUR_PLAID_CLIENT_ID
  secret: YOUR_PLAID_SECRET
  environment: sandbox  # Options: sandbox, development, production
  token-encryption-key: YOUR_PLAID_TOKEN_ENCRYPTION_KEY  # Min 32 characters recommended
  token-encryption-salt: YOUR_PLAID_TOKEN_ENCRYPTION_SALT  # Hex string e.g. deadbeef01234567

