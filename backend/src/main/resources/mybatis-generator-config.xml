<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE generatorConfiguration
  PUBLIC "-//mybatis.org//DTD MyBatis Generator Configuration 1.0//EN"
  "http://mybatis.org/dtd/mybatis-generator-config_1_0.dtd">

<generatorConfiguration>
  <properties resource="generator.properties"/>
  
  <context id="PostgresContext" targetRuntime="MyBatis3">
    
    <!-- Optional: Plugin for adding @Mapper annotation -->
    <plugin type="org.mybatis.generator.plugins.MapperAnnotationPlugin"/>
    
    <!-- Overwrite XML mapper files instead of merging -->
    <plugin type="org.mybatis.generator.plugins.UnmergeableXmlMappersPlugin"/>
    
    <!-- Comment generator settings -->
    <commentGenerator>
      <property name="suppressDate" value="true"/>
      <property name="suppressAllComments" value="true"/>
    </commentGenerator>

    <!-- Database connection - reads from generator.properties -->
    <jdbcConnection driverClass="${jdbc.driverClass}"
                    connectionURL="${jdbc.connectionURL}"
                    userId="${jdbc.userId}"
                    password="${jdbc.password}">
      <!-- Ensures proper schema handling for PostgreSQL -->
      <property name="nullCatalogMeansCurrent" value="true"/>
    </jdbcConnection>

    <!-- Java Type Resolver -->
    <javaTypeResolver>
      <property name="forceBigDecimals" value="false"/>
      <property name="useJSR310Types" value="true"/>  <!-- Use LocalDateTime instead of Date -->
    </javaTypeResolver>

    <!-- 1. WHERE TO PUT GENERATED MODEL/ENTITY CLASSES -->
    <javaModelGenerator targetPackage="com.killeen.dashboard.db.model.generated" 
                        targetProject="src/main/java">
      <property name="enableSubPackages" value="false"/>
      <property name="trimStrings" value="true"/>
    </javaModelGenerator>

    <!-- 2. WHERE TO PUT GENERATED XML MAPPER FILES -->
    <sqlMapGenerator targetPackage="db.mapper.generated" 
                     targetProject="src/main/resources">
      <property name="enableSubPackages" value="false"/>
    </sqlMapGenerator>

    <!-- 3. WHERE TO PUT GENERATED JAVA MAPPER INTERFACES -->
    <javaClientGenerator type="XMLMAPPER" 
                         targetPackage="com.killeen.dashboard.db.mapper.generated" 
                         targetProject="src/main/java">
      <property name="enableSubPackages" value="false"/>
    </javaClientGenerator>

    <!-- ========================================== -->
    <!-- TABLES TO GENERATE -->
    <!-- ========================================== -->
    
    <!-- Plaid Items Table -->
    <table tableName="plaid_items" 
           domainObjectName="PlaidItemDb">
      
      <!-- Specify the primary key for proper key generation -->
      <generatedKey column="id" sqlStatement="JDBC" identity="true"/>
      
      <!-- Optional: Override column to property mapping if needed -->
      <!-- <columnOverride column="item_id" property="itemId" javaType="java.lang.String"/> -->
    </table>

    <!-- Users Table -->
    <table tableName="users" 
           domainObjectName="UserDb">
      <generatedKey column="id" sqlStatement="JDBC" identity="true"/>
    </table>

    <!-- Email Tokens Table-->
    <table
      tableName="email_tokens"
      domainObjectName="EmailTokenDb">
      <generatedKey column="id" sqlStatement="JDBC" identity="true" />

      <!-- token_type is a PostgreSQL enum; use a custom TypeHandler so MyBatis
           calls setObject(..., Types.OTHER) instead of setString() on writes -->
      <columnOverride column="token_type"
                      javaType="java.lang.String"
                      typeHandler="com.killeen.dashboard.db.typehandler.PostgresEnumTypeHandler" />

    </table>

  </context>
</generatorConfiguration>
